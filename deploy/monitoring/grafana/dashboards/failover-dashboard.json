{
  "title": "Continuity — Failover Effectiveness",
  "uid": "continuity-failover",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "First-copy rate by path (which uplink is delivering)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "pps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (path) (rate(continuity_packets_total{decision=\"first-copy\"}[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Duplicate rate by path (redundancy working)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "pps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (path) (rate(continuity_packets_total{decision=\"duplicate\"}[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Rejected rate by reason",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "pps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (reason) (rate(continuity_rejected_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Delivery share by path (first copies, 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (path) (increase(continuity_packets_total{decision=\"first-copy\"}[1h])) / ignoring(path) group_left sum(increase(continuity_packets_total{decision=\"first-copy\"}[1h]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Gateway scrape state (up = reachable)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"continuity-gateway\"}",
          "legendFormat": "gateway"
        }
      ]
    }
  ]
}
